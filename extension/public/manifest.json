{
    "manifest_version": 3,
    "name": "Vernacular AI Bridge",
    "version": "1.0",
    "description": "LMS AI Assistant with Kannada Translation",
    "permissions": [
        "sidePanel",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "side_panel": {
        "default_path": "index.html"
    },
    "action": {
        "default_title": "Open Vernacular AI Bridge"
    }
}